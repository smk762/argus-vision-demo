# ── Frontend ──────────────────────────────────────────────────────────
# URL the browser uses to reach the argus-lens API (must be NEXT_PUBLIC_* for Next.js).
# Local dev: this file at repo root is loaded by next.config.ts. Docker: set before
# `docker compose build` (value is baked into the client bundle at build time).
NEXT_PUBLIC_API_URL=http://localhost:8100

# URL the browser uses to reach the argus-curator API.
NEXT_PUBLIC_CURATOR_URL=http://localhost:8101

# Curator SPA layout (baked in at build time for Docker).
# demo — browser upload + zip download (public live demo).
# local — scan/export use directories on the curator host; prefill paths below.
NEXT_PUBLIC_CURATOR_UI_MODE=demo

# Used when NEXT_PUBLIC_CURATOR_UI_MODE=local. These are paths as seen by argus-curator
# (the machine/container running the API on CURATOR_URL), NOT paths on your laptop browser.
# This repo's compose.yaml does not start argus-curator — you define mounts there yourself.
# Example: docker run -v ~/my-dataset:/data/images -v ~/out:/data/out … argus-curator
#          → SOURCE=/data/images, OUTPUT=/data/out (mount targets on the curator side).
NEXT_PUBLIC_CURATOR_SOURCE_PATH=/data/images
NEXT_PUBLIC_CURATOR_OUTPUT_PATH=/data/out

# Host port for the Next.js frontend (Docker only).
FRONTEND_PORT=3000
